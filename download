import uuid
import logging

from pyrogram import Client, filters, StopPropagation
from pyrogram.types import Message
from telegraph import upload_file

from Devil.utils import get_user_tmp, cleanup_user_tmp, SHARE_BUTTON, SUCCESS_TEXT, ERROR_TEXT

logger = logging.getLogger(__name__)

# Supported MIME types and their file extensions
SUPPORTED_MIME = {
    "image/png": ".png",
    "image/jpeg": ".jpg",
    "image/gif": ".gif",
    "video/mp4": ".mp4",
    "audio/mpeg": ".mp3",
    "audio/mp3": ".mp3",
}


@Client.on_message(filters.document)
async def handle_document(client: Client, message: Message):
    """Handle files sent as documents: PNG, GIF, MP4, MP3."""
    doc = message.document

    if not doc:
        return

    mime = doc.mime_type or ""
    ext = SUPPORTED_MIME.get(mime)

    if not ext:
        await message.reply_text(
            f"❌ **Unsupported file type:** `{mime}`\n\n"
            "Supported: PNG, GIF, MP4, MP3 (sent as document)"
        )
        return

    chat_id = message.chat.id
    tmp = get_user_tmp(chat_id)
    file_path = f"{tmp}/{uuid.uuid4()}{ext}"

    status = await message.reply_text(f"📥 Downloading `{ext.lstrip('.')}` file...")

    try:
        file_path = await client.download_media(message=message, file_name=file_path)
        await status.edit_text("📤 Uploading to Telegraph...")

        response = upload_file(file_path)
        tg_url = f"https://telegra.ph{response[0]}"

        await status.edit_text(
            SUCCESS_TEXT.format(url=tg_url),
            disable_web_page_preview=True,
            reply_markup=SHARE_BUTTON(tg_url),
        )

    except Exception as e:
        logger.error(f"Document upload error ({mime}): {e}")
        await status.edit_text(ERROR_TEXT.format(error=str(e)))

    finally:
        cleanup_user_tmp(chat_id)

    raise StopPropagation
